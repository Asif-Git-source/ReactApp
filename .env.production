# ─── Production Overrides ───────────────────────────────────────────────────
# Merged on top of .env when running: vite build
# VITE_SENTRY_DSN must be set in your CI environment, not here
# (never commit real DSNs to source control)

VITE_SENTRY_ENVIRONMENT=production

# Lower sample rates in production to control Sentry quota
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.1
