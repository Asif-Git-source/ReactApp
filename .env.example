# ─── Environment Variable Reference ─────────────────────────────────────────
# Copy this file to .env and fill in values.
# .env is gitignored. This file IS committed as a reference.
#
# VITE_ prefix → exposed to the browser (safe for public values only)
# No prefix     → build-time only, never in the bundle

# App metadata
VITE_APP_NAME=DevBoard
VITE_APP_VERSION=1.0.0

# Sentry — browser monitoring
# Get DSN from: sentry.io → Your Project → Settings → SDK Setup
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.1

# Sentry source map upload (build-time only — never exposed to browser)
# Generate token: sentry.io → Settings → Auth Tokens
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_your_token_here
