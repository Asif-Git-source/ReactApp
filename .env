# ─── Development Environment ────────────────────────────────────────────────
# VITE_ prefix = exposed to the browser bundle
# Variables without VITE_ are build-time only (CI/CD, Vite plugins)

VITE_APP_NAME=DevBoard
VITE_APP_VERSION=1.0.0

# Sentry — leave DSN empty to disable Sentry in local development
# Set it to your project DSN to test Sentry locally
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.1
